{
  "name": "mediahub-web",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.23.0",
  "type": "module",
  "scripts": {
    "api:generate": "node scripts/generate-openapi-client.mjs",
    "api:check": "node scripts/verify-openapi.mjs && node scripts/generate-openapi-client.mjs --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "dev": "vite",
    "build": "pnpm api:check && tsc -b && vite build && pnpm verify:viewer-chunks",
    "verify:viewer-chunks": "node scripts/verify-viewer-chunks.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@heroui/react": "^3.2.2",
    "@heroui/styles": "^3.2.2",
    "@hookform/resolvers": "^3.9.1",
    "@open-file-viewer/core": "^0.1.20",
    "@open-file-viewer/react": "^0.1.20",
    "@tanstack/react-query": "^5.62.7",
    "hash-wasm": "^4.12.0",
    "jszip": "^3.10.1",
    "libarchive.js": "2.0.2",
    "lucide-react": "^0.468.0",
    "openapi-fetch": "^0.14.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.54.0",
    "react-router-dom": "^6.28.0",
    "sevenzip-wasm": "26.2.0",
    "sql.js": "^1.14.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^26.1.0",
    "openapi-typescript": "^7.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.6.3",
    "vite": "^8.1.5",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
    }
  }
}
