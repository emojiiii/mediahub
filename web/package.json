{
  "name": "mediahub-web",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.15.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:test": "vite --mode test",
    "build": "pnpm api:check && pnpm typecheck && vite build && pnpm verify:viewer-chunks",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "api:generate": "node scripts/generate-openapi-client.mjs",
    "api:check": "node scripts/verify-openapi.mjs && node scripts/generate-openapi-client.mjs --check",
    "verify:viewer-chunks": "node scripts/verify-viewer-chunks.mjs"
  },
  "dependencies": {
    "@heroui/react": "^3.2.2",
    "@heroui/styles": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@open-file-viewer/core": "^0.1.26",
    "@open-file-viewer/react": "^0.1.26",
    "@tanstack/react-query": "^5.101.2",
    "hash-wasm": "^4.12.0",
    "jszip": "^3.10.1",
    "libarchive.js": "2.0.2",
    "lucide-react": "^1.25.0",
    "openapi-fetch": "^0.17.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.82.0",
    "react-router-dom": "^7.18.1",
    "sevenzip-wasm": "26.2.0",
    "sql.js": "^1.14.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.1.10"
  }
}
