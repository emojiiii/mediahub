# Copy this file to .env. Never commit the populated .env file.
# Generate each key independently with a cryptographically secure random source.
# PowerShell example:
#   $bytes = [byte[]]::new(32)
#   [System.Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($bytes)
#   [Convert]::ToBase64String($bytes)

MEDIAHUB_IMAGE=ghcr.io/emojiiii/mediahub:latest
MEDIAHUB_POSTGRES_DB=mediahub
MEDIAHUB_POSTGRES_USER=mediahub
MEDIAHUB_POSTGRES_PASSWORD=

MEDIAHUB_ACCESS_KEY_MASTER_KEY=
MEDIAHUB_ACCESS_KEY_MASTER_KEY_VERSION=1
MEDIAHUB_MEDIA_SIGNING_KEY=

MEDIAHUB_EMAIL_PROVIDER_URL=https://mail.example.com/mediahub/tokens
MEDIAHUB_EMAIL_PROVIDER_TOKEN=
MEDIAHUB_EMAIL_FROM=mediahub@example.com

MEDIAHUB_REGISTRATION_ENABLED=false
MEDIAHUB_CORS_ALLOWED_ORIGINS=https://console.example.com
MEDIAHUB_ALLOW_INSECURE_COOKIES=false
MEDIAHUB_COOKIE_SAME_SITE=lax
